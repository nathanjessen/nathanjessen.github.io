{
  "name": "nathanjessen",
  "version": "2.1.0",
  "description": "Personal website of web developer, Nathan Jessen",
  "homepage": "http://nathanjessen.github.io",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.17",
    "cross-env": "^7.0.3",
    "cssnano": "^7.0.6",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.0",
"tailwindcss": "^3.4.1"
  },
  "scripts": {
    "build": "cross-env JEKYLL_ENV=production bundle exec jekyll build && postcss _styles/style.css -o _site/assets/css/style.css",
    "dev": "docker-compose up --build",
    "start": "npm run dev",
    "stop": "docker-compose down",
    "clean": "docker-compose down -v"
  },
  "repository": {
    "type": "git",
    "url": "https://nathanjessen@github.com/nathanjessen/nathanjessen.github.io.git"
  },
  "bugs": {
